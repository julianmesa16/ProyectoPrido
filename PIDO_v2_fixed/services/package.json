{
  "name": "pido-services",
  "version": "2.0.0",
  "description": "PIDO – Microservicios backend",
  "scripts": {
    "auth":      "node auth/index.js",
    "accounts":  "node accounts/index.js",
    "exchange":  "node exchange/index.js",
    "transfers": "node transfers/index.js",
    "admin":     "node admin/index.js",
    "start": "node ./node_modules/concurrently/dist/bin/concurrently.js \"npm run auth\" \"npm run accounts\" \"npm run exchange\" \"npm run transfers\" \"npm run admin\""
  },
  "dependencies": {
    "cors":         "^2.8.5",
    "express":      "^4.18.2",
    "mysql2":       "^3.6.0",
    "concurrently": "^8.2.0"
  }
}
